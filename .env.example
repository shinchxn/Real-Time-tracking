# ── Content DNA v7.1 Apex — Required Environment Variables ────────
# Copy this file to .env and configure for the Apex Edition.

# ── API & Security ─────────────────────────────────────────────
API_KEY_SECRET=generate-a-secure-secret-here
FERNET_KEY=generate-a-fernet-key-for-sessions-here
DEBUG=false

# ── Database & Cache ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contentdna
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_URL=redis://localhost:6379/1

# ── Blockchain & Provenance ────────────────────────────────────
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/your-key
CONTENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
WALLET_PRIVATE_KEY=your-private-key-here
ZK_PROOF_DIR=./data/proofs

# ── Hunting Grid (Discovery) ───────────────────────────────────
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_SEARCH_CX=your-custom-search-engine-id
INSTAGRAM_USERNAME=your-instagram-username
INSTAGRAM_PASSWORD=your-instagram-password
TINEYE_API_KEY=your-tineye-key

# ── AI & Forensic Backbone ─────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-key-here
CLIP_MODEL=openai/clip-vit-base-patch32
THRESHOLD_CRITICAL=0.96
THRESHOLD_HIGH=0.88
THRESHOLD_MEDIUM=0.75

# ── Multimedia Core ────────────────────────────────────────────
VIDEO_FPS=1
AUDIO_SR=22050
MAX_FILE_SIZE=524288000 # 500MB

# ── DMCA Automation ────────────────────────────────────────────
DMCA_AUTOMATION_ENABLED=true
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx
EVIDENCE_DIR=./data/evidence
