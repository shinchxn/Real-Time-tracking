# ── Content DNA — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_BUCKET=content-dna-assets

# ── NVIDIA API (fallback embedding) ─────────────────────────
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/embeddings

# ── CLIP Model ───────────────────────────────────────────────
CLIP_MODEL=ViT-L/14
CLIP_EMBEDDING_DIM=768
USE_CUDA=true

# ── FAISS ────────────────────────────────────────────────────
FAISS_NLIST=256
FAISS_NPROBE=32
FAISS_PERSIST_INTERVAL=300

# ── Thresholds ───────────────────────────────────────────────
THRESHOLD_CRITICAL=0.94
THRESHOLD_HIGH=0.85
THRESHOLD_MEDIUM=0.72

# ── Fusion Weights ───────────────────────────────────────────
WEIGHT_CLIP=0.55
WEIGHT_PHASH=0.25
WEIGHT_COLOR=0.12
WEIGHT_HOG=0.08

# ── Watermark ────────────────────────────────────────────────
WATERMARK_ALPHA=0.08

# ── Alerts ───────────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ── General ──────────────────────────────────────────────────
DEBUG=false
