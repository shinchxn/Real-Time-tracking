# ── Content DNA v3 Apex — Environment Variables ────────────────
# Copy this file to .env and configure for the Apex Edition.

# ── Supabase (Scalable Cloud Storage) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_BUCKET=content-dna-assets

# ── NVIDIA Hybrid Analysis (GPU Fallback) ─────────────────────
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/embeddings

# ── CLIP DNA Backbone ──────────────────────────────────────────
CLIP_MODEL=ViT-L/14
CLIP_EMBEDDING_DIM=768
USE_CUDA=true

# ── 6-Layer DNA Fusion Weights ────────────────────────────────
WEIGHT_CLIP=0.40
WEIGHT_CLIP_SPATIAL=0.15 # New v3 Apex (Spatial Attention)
WEIGHT_PHASH=0.15
WEIGHT_DCT_SIG=0.15      # New v3 Apex (Frequency Signature)
WEIGHT_COLOR=0.10
WEIGHT_HOG=0.05

# ── Multimedia Core (Video/Audio) ─────────────────────────────
VIDEO_FPS=1
AUDIO_SR=22050
MAX_FILE_SIZE=524288000 # 500MB (Supports high-res source video)

# ── ZK-Proof & Blockchain ─────────────────────────────────────
ZK_PROOF_DIR=./data/proofs
CHAIN_PROVIDER_URL=https://polygon-mainnet.g.alchemy.com/v2/your-key

# ── Thresholds (High Precision Apex) ──────────────────────────
THRESHOLD_CRITICAL=0.96
THRESHOLD_HIGH=0.88
THRESHOLD_MEDIUM=0.75

# ── DMCA Automation & Intelligence ───────────────────────────
DMCA_AUTOMATION_ENABLED=true
ALERT_WEBHOOK_URL=

# ── Infrastructure (FAISS / DB) ───────────────────────────────
DEBUG=false
FAISS_NLIST=512
FAISS_NPROBE=64
FAISS_PERSIST_INTERVAL=300
SQLITE_PATH=./data/fallback.db
